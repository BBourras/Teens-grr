{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}
<div class="container mt-4">

    <h1 class="mb-4">Derniers posts</h1>

    {% for data in postsData %}
        {% set post = data.post %}
        {% set comments = data.comments %}
        {% set score = data.score %}

        <div class="card mb-4 shadow-sm">
            <div class="card-body">

                <h3 class="card-title">{{ post.title }}</h3>

                <p class="text-muted mb-2">
                    Posté par <strong>{{ post.author.username }}</strong>
                    le {{ post.createdAt|date('d/m/Y H:i') }}
                </p>

                <p class="card-text">
                    {{ post.content }}
                </p>

                <div class="mb-2">
                    <strong>Score :</strong> {{ score }}
                </div>

                <hr>

                <h5>Commentaires ({{ comments|length }})</h5>

                {% for comment in comments %}
                    <div class="border rounded p-2 mb-2 bg-light">
                        <strong>{{ comment.author.username }}</strong>
                        <small class="text-muted">
                            le {{ comment.createdAt|date('d/m/Y H:i') }}
                        </small>
                        <div>
                            {{ comment.content }}
                        </div>
                    </div>
                {% else %}
                    <p class="text-muted">Aucun commentaire pour le moment.</p>
                {% endfor %}

            </div>
        </div>

    {% else %}
        <p>Aucun post disponible.</p>
    {% endfor %}

</div>
{% endblock %}