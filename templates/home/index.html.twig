{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}

    <div class="mb-5">
        <h1>Bienvenue sur Teens-GRR 🔥</h1>
        <p class="text-muted">
            Les discussions les plus populaires et les plus récentes.
        </p>
    </div>

    {# =============================== #}
    {# POSTS POPULAIRES               #}
    {# =============================== #}
    <section class="mb-5">
        <h3>🔥 Posts populaires</h3>

        {% if topPosts is empty %}
            <p class="text-muted">Aucun post populaire pour le moment.</p>
        {% else %}
            {% for post in topPosts %}
                {% include 'partials/posts/_post_card.html.twig' with { post: post } %}
            {% endfor %}
        {% endif %}
    </section>

    {# =============================== #}
    {# DERNIERS POSTS                 #}
    {# =============================== #}
    <section>
        <h3>🆕 Derniers posts</h3>

        {% if latestPosts is empty %}
            <p class="text-muted">Aucun post publié récemment.</p>
        {% else %}
            {% for post in latestPosts %}
                {% include 'partials/posts/_post_card.html.twig' with { post: post } %}
            {% endfor %}
        {% endif %}
    </section>

{% endblock %}