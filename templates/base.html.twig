{# templates/base.html.twig #}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        {# Bloc pour le titre de la page, à surcharger dans chaque template #}
        {% block title %}TeensGRR{% endblock %}
    </title>

    {# Ici tu peux inclure CSS global (Bootstrap, custom styles, etc.) #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    {# Bloc pour ajouter des styles spécifiques à certaines pages #}
    {% block stylesheets %}{% endblock %}
</head>
<body>
    {# ============================= #}
    {# Navbar : partial séparé pour réutilisation #}
    {# ============================= #}
    {% include 'partials/_navbar.html.twig' %}

    <div class="container mt-4">

        {# ============================= #}
        {# Flash messages : succès / erreur #}
        {# Partial séparé pour centraliser l'affichage #}
        {# ============================= #}
        {% include 'partials/_flash_messages.html.twig' %}

        {# ============================= #}
        {# Contenu principal de la page #}
        {# Chaque template fille doit surcharger ce bloc #}
        {# ============================= #}
        {% block body %}{% endblock %}
    </div>

    {# ============================= #}
    {# Scripts JS globaux (Bootstrap, Popper, etc.) #}
    {# ============================= #}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    {# Bloc pour ajouter des scripts spécifiques à certaines pages #}
    {% block javascripts %}{% endblock %}
</body>
</html>