<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Teens-grr{% endblock %}</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand" href="{{ path('home') }}">Teens-grr</a>

        <div class="ms-auto">
            {% if app.user %}
                <span class="text-light me-3">
                    👤 {{ app.user.username }}
                </span>
                <a href="{{ path('app_logout') }}" class="btn btn-sm btn-outline-light">Logout</a>
            {% else %}
                <a href="{{ path('app_login') }}" class="btn btn-sm btn-outline-light me-2">Login</a>
                <a href="{{ path('app_register') }}" class="btn btn-sm btn-warning">Register</a>
            {% endif %}
        </div>
    </div>
</nav>

<div class="container mt-4">
    {% include 'partials/_flash_messages.html.twig' %}
    {% block body %}{% endblock %}
</div>

</body>
</html>