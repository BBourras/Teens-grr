{# templates/base.html.twig #}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Teens Grr{% endblock %}</title>

    {# Bootstrap CSS ou autre framework – on peut le mettre plus tard #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    
    {# Bloc pour ajouter des styles spécifiques à chaque page #}
    {% block stylesheets %}{% endblock %}
</head>
<body>
    {# ========================
       Navbar globale
       ======================== #}
    {% include 'partials/_navbar.html.twig' %}

    <div class="container mt-4">
        {# ========================
           Flash messages
           Affiche les alertes flash de Symfony
           ======================== #}
        {% include 'partials/flash/_flash_messages.html.twig' %}

        {# ========================
           Contenu principal de la page
           Chaque page remplira ce bloc
           ======================== #}
        {% block body %}{% endblock %}
    </div>

    {# ========================
       Footer global
       ======================== #}
    <footer class="mt-5 py-3 bg-light text-center">
        <small>&copy; {{ "now"|date("Y") }} Teens Grr - Tous droits réservés</small>
    </footer>

    {# ========================
       Scripts JS
       ======================== #}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    {% block javascripts %}{% endblock %}
</body>
</html>