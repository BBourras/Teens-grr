{% extends 'base.html.twig' %}

{% block title %}{{ post.title }}{% endblock %}

{% block body %}

<div class="card mb-4 shadow-sm">
    <div class="card-body">

        <h2>{{ post.title }}</h2>

        <p class="text-muted">
            Par <strong>{{ post.author.username }}</strong>
            • {{ post.createdAt|date('d/m/Y H:i') }}
        </p>

        {% if post.status.name != 'PUBLISHED' %}
            <div class="alert alert-warning">
                ⚠ Ce post est actuellement {{ post.status.name|lower|replace({'_':' '}) }}
            </div>
        {% endif %}

        <p class="mt-3">
            {{ post.content|nl2br }}
        </p>

        <hr>

        {# Vote #}
        <div class="mb-3">
            <form method="post"
                  action="{{ path('vote_post', { postId: post.id }) }}"
                  class="d-flex gap-2">

                <button name="type" value="like" class="btn btn-sm btn-success">
                    👍 Like
                </button>

                <button name="type" value="laugh" class="btn btn-sm btn-warning">
                    😂 Laugh
                </button>

                <button name="type" value="angry" class="btn btn-sm btn-danger">
                    😡 Angry
                </button>

                <span class="ms-3 align-self-center">
                    Score : <strong>{{ post.reactionScore }}</strong>
                </span>
            </form>
        </div>

        {# Actions post #}
        <div class="d-flex gap-2">

            {% if is_granted('POST_EDIT', post) %}
                <a href="{{ path('post_edit', { postId: post.id }) }}"
                   class="btn btn-sm btn-outline-secondary">
                    Modifier
                </a>
            {% endif %}

            {% if is_granted('ROLE_USER') %}
                <form method="post"
                      action="{{ path('report_post', { postId: post.id }) }}">
                    <button class="btn btn-sm btn-outline-warning">
                        Signaler
                    </button>
                </form>
            {% endif %}

        </div>

    </div>
</div>

{# ========================= #}
{# COMMENTAIRES #}
{# ========================= #}

<h4 class="mb-3">
    💬 Commentaires ({{ post.commentCount }})
</h4>

{% if is_granted('ROLE_USER') %}
    {% include 'partials/_comment_form.html.twig' with {
        form: form,
        button_label: 'Publier'
    } %}
{% else %}
    <div class="alert alert-light">
        <a href="{{ path('app_login') }}">Connectez-vous</a> pour commenter.
    </div>
{% endif %}

{% for comment in post.comments %}
    {% include 'partials/_comment.html.twig' with { comment: comment } %}
{% else %}
    <p class="text-muted">Aucun commentaire pour le moment.</p>
{% endfor %}

{% endblock %}