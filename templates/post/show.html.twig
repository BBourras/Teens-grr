{% extends 'base.html.twig' %}

{% block title %}{{ post.title }}{% endblock %}

{% block body %}
<div class="card mb-4 shadow-sm">
    <div class="card-body">

        {# ========================= #}
        {# TITRE ET MÉTADATA DU POST #}
        {# ========================= #}
        <h2>{{ post.title }}</h2>

        <p class="text-muted">
            Par <strong>{{ post.author.username }}</strong>
            • {{ post.createdAt|date('d/m/Y H:i') }}
        </p>

        {# Alerte si post non publié #}
        {% if post.status.name != 'PUBLISHED' %}
            <div class="alert alert-warning">
                ⚠ Ce post est actuellement
                {{ post.status.name|lower|replace({'_':' '}) }}
            </div>
        {% endif %}

        <p class="mt-3">
            {{ post.content|nl2br }}
        </p>

        <hr>

        {# ========================= #}
        {# BLOC VOTE (réutilisable) #}
        {# ========================= #}
        {# postVotes est fourni par le contrôleur #}
        {% include 'partials/posts/_vote_buttons.html.twig' with {
            post: post,
            postVotes: postVotes
        } %}

        <hr>

        {# ========================= #}
        {# ACTIONS SUR LE POST #}
        {# ========================= #}
        <div class="d-flex gap-2">

            {% if is_granted('POST_EDIT', post) %}
                <a href="{{ path('post_edit', { id: post.id }) }}"
                   class="btn btn-sm btn-outline-secondary">
                    Modifier
                </a>
            {% endif %}

            {% if is_granted('ROLE_USER') %}
                <form method="post"
                      action="{{ path('report_post', { id: post.id }) }}">
                    <button class="btn btn-sm btn-outline-warning">
                        Signaler
                    </button>
                </form>
            {% endif %}

        </div>

    </div>
</div>

{# ========================= #}
{# COMMENTAIRES #}
{# ========================= #}

<h4 class="mb-3">
    💬 Commentaires ({{ post.commentCount }})
</h4>

{% if is_granted('ROLE_USER') %}
    {{ form_start(form, {
        'action': path('comment_create', {'id': post.id}),
        'method': 'POST'
    }) }}

        {{ form_row(form.content) }}

        <button type="submit" class="btn btn-primary">
            {{ button_label|default('Publier') }}
        </button>

    {{ form_end(form) }}
{% else %}
    <div class="alert alert-light">
        <a href="{{ path('app_login') }}">Connectez-vous</a>
        pour commenter.
    </div>
{% endif %}

{% for comment in post.comments %}
    {% include 'partials/comments/_comment_item.html.twig' with {
        comment: comment
    } %}
{% else %}
    <p class="text-muted">Aucun commentaire pour le moment.</p>
{% endfor %}

{% endblock %}