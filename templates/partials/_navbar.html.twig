{# templates/partials/_navbar.html.twig #}
<nav class="navbar navbar-expand-lg navbar-light bg-light">
    <div class="container-fluid">

        {# Logo / Nom du site #}
        <a class="navbar-brand" href="{{ path('home') }}">Teens Grr</a>

        {# Bouton responsive mobile #}
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarSupportedContent">

            {# ============================= #}
            {# NAV PRINCIPALE (3 boutons)   #}
            {# ============================= #}
            <ul class="navbar-nav me-auto mb-2 mb-lg-0 d-flex align-items-center">

                {# Groupe 1 : Flux #}
                <li class="nav-item me-3">
                    <a class="nav-link" href="{{ path('post_list') }}">📰 Flux</a>
                </li>

                {# Séparation verticale #}
                <li class="vr"></li>

                {# Groupe 2 : Top du moment + Légendes #}
                <li class="nav-item me-3">
                    <a class="nav-link" href="{{ path('post_top') }}">🔥 Top du moment</a>
                </li>
                <li class="nav-item me-2">
                    <a class="nav-link" href="{{ path('post_legendes') }}">🏛 Légendes</a>
                </li>
				
				{# Séparation verticale #}
                <li class="vr"></li>
            </ul>

            {# ============================= #}
            {# UTILISATEUR (droite)         #}
            {# ============================= #}
            <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                {% if app.user %}
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            {{ app.user.username }}
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                            <li><a class="dropdown-item" href="{{ path('post_new') }}">✍️ Créer un post</a></li>
                            {% if is_granted('ROLE_MODERATOR') %}
                                <li><a class="dropdown-item" href="{{ path('moderation_dashboard') }}">🛠 Modération</a></li>
                            {% endif %}
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="{{ path('app_logout') }}">🚪 Déconnexion</a></li>
                        </ul>
                    </li>
                {% else %}
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_login') }}">Connexion</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_register') }}">Inscription</a></li>
                {% endif %}
            </ul>
        </div>
    </div>
</nav>