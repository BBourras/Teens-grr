{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<h1>Connexion</h1>

{% if error %}
    <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
{% endif %}

<form method="post" action="{{ path('app_login') }}">
    <div class="mb-3">
        <label for="inputEmail">Email</label>
        <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control" required autofocus>
    </div>

    <div class="mb-3">
        <label for="inputPassword">Mot de passe</label>
        <input type="password" name="password" id="inputPassword" class="form-control" required>
    </div>

    <div class="mb-3 form-check">
        <input type="checkbox" name="_remember_me" id="remember_me" class="form-check-input">
        <label for="remember_me" class="form-check-label">Se souvenir de moi</label>
    </div>

    <button class="btn btn-primary">Se connecter</button>
</form>

<p class="mt-2">
    Pas encore de compte ? <a href="{{ path('app_register') }}">S’inscrire</a>
</p>
{% endblock %}